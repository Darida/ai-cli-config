{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(go mod *)",
      "Bash(go test *)"
    ],
    "deny": [
      "Bash(git branch -D*)",
      "Bash(git branch --delete*)"
    ],
    "defaultMode": "auto"
  },
  "model": "haiku",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/bash-guard/block-git-branch-changes.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /home/daridagm/.claude/statusline-command.sh"
  },
  "theme": "dark",
  "verbose": true,
  "remoteControlAtStartup": true,
  "useAutoModeDuringPlan": true
}
