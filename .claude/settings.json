{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(go mod *)",
      "Bash(go test *)",
      "Bash(git pull *)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(git push *)",
      "Bash(cat)",
      "Read(//tmp/**)",
      "Bash(git commit *)",
      "Bash(git reset *)"
    ],
    "deny": [
      "Bash(git branch -D*)",
      "Bash(git branch --delete*)",
      "Bash(cd *)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/bash-guard/block-git-branch-changes.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /home/daridagm/.claude/statusline-command.sh"
  },
  "theme": "dark",
  "verbose": true,
  "remoteControlAtStartup": true,
  "useAutoModeDuringPlan": true
}
